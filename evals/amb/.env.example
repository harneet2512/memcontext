# MemContext × AMB — environment configuration
# Copy to the agent-memory-benchmark/ directory as `.env` and fill in keys.

# ── Extractor: DeepSeek V4 Flash (DeepSeek platform, gets cache discount) ──
MEMCONTEXT_EXTRACTOR_BACKEND=openrouter
MEMCONTEXT_EXTRACTOR_ENDPOINT=https://api.deepseek.com/chat/completions
MEMCONTEXT_EXTRACTOR_MODEL=deepseek-chat
MEMCONTEXT_EXTRACTOR_API_KEY=sk-your-deepseek-key
MEMCONTEXT_EXTRACTION_WORKERS=20

# ── Reader / Judge routed through OpenRouter (AMB default models) ──
OPENAI_API_KEY=sk-or-v1-your-openrouter-key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OMB_ANSWER_LLM=openai
OMB_ANSWER_MODEL=openai/gpt-oss-120b
OMB_JUDGE_LLM=openai
OMB_JUDGE_MODEL=google/gemini-2.5-flash-lite

# AMB checks for this at startup even when routing through OpenRouter; any value works.
GEMINI_API_KEY=not-used-routing-via-openrouter

# ── MemContext ──
ACTIVE_PACK=personal_assistant
PYTHONIOENCODING=utf-8
