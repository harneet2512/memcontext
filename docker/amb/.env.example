# MemContext × AMB reproducible trial — runtime keys/config.
# Pass to the container with:  docker run --env-file docker/amb/.env.example ...
# (copy this file, fill in real keys, and DO NOT commit the filled copy)

# ── PER-ROLE gateway keys (OpenAI-compatible) ──
# Each role bills to its OWN key on its OWN gateway. Pass the real keys at runtime
# (-e ANSWER_KEY=... etc.) — never commit filled values. PLACEHOLDERS ONLY below.

# Answer role (free key) — OpenRouter — model openai/gpt-oss-120b
ANSWER_KEY=sk-or-v1-your-ANSWER-key-here
OMB_ANSWER_OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OMB_ANSWER_MODEL=openai/gpt-oss-120b

# Judge role (paid key — distinct from the answer key) — model google/gemini-3-flash-preview
JUDGE_KEY=tr-your-JUDGE-key-here
OMB_JUDGE_OPENAI_BASE_URL=https://api.tokenrouter.com/v1
# OMB_JUDGE_MODEL=google/gemini-3-flash-preview

# Extractor (MemContext's own LLM extractor — its own key) — model minimax/minimax-m3
EXTRACTOR_KEY=tr-your-EXTRACTOR-key-here
MEMCONTEXT_EXTRACTOR_ENDPOINT=https://api.tokenrouter.com/v1/chat/completions
# MEMCONTEXT_EXTRACTOR_MODEL=minimax/minimax-m3
# MEMCONTEXT_EXTRACTOR_NO_THINK=1

# AMB probes for this at startup even when routing via a gateway; any value works.
GEMINI_API_KEY=not-used-routing-via-gateway

# ── Product ──
# Semantic memory (Pass-2 supersession + semantic retrieval) is ON by default.
# Setting this to 0 forces DEGRADED lexical-only mode — do not do this for a real run.
# MEMCONTEXT_EMBED_EPISODES=1
# ACTIVE_PACK=personal_assistant
# Extraction parallelism (default 64). Tune to the extractor key's RPM/TPM.
# MEMCONTEXT_EXTRACTION_WORKERS=64
